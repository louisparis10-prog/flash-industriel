# ============================================================
# FLASH INDUSTRIEL — Variables d'environnement
# Copier ce fichier en ".env" et remplir les valeurs
# ============================================================

# Numéro de port sur lequel l'appli sera accessible (ex: 3001)
PORT=3001

# Nom ou IP du serveur SQL Server (ex: SRVPROD, 192.168.1.10, SRVPROD\SQLEXPRESS)
DB_SERVER=VOTRE_SERVEUR

# Nom de la base de données
DB_NAME=flash_industriel

# Identifiant SQL Server
DB_USER=flash_user

# Mot de passe SQL Server
DB_PASSWORD=VOTRE_MOT_DE_PASSE

# Port SQL Server (1433 par défaut)
DB_PORT=1433
